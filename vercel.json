{
    "version": 2,
    "builds": [
        {
            "src": "client/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "server/server.js",
            "use": "@vercel/node"
        }
    ],
    "rewrites": [
        {
            "source": "/api/v1/:path*",
            "destination": "/server/server.js"
        },
        {
            "source": "/uploads/:path*",
            "destination": "/server/server.js"
        },
        {
            "source": "/:path*",
            "destination": "/index.html"
        }
    ]
}
